# Customs Control Tower — environment variables (NAMES are fixed by the build).
# Copy to the Coolify app environment. Values shown here are SAFE NON-SECRET placeholders.
# Secrets (DATABASE_URL password, SESSION_SECRET, S3 keys, ANTHROPIC_API_KEY) are owner-supplied
# at deploy time. NEVER commit real values. No localhost — every endpoint is a live service.

# --- Runtime ---
NODE_ENV=production
PORT=8080
# Public base URL of the deployed app (used for absolute links in emails, signed-URL host).
PUBLIC_BASE_URL=https://cct.example.com
# Spanish-first default locale (es | en).
DEFAULT_LOCALE=es
# Comma-separated extra allowed origins for CORS. Empty = same-origin only (the default; recommended).
CORS_ORIGINS=

# --- Database (PostgreSQL 16, Coolify service) ---
# Internal Coolify service hostname for Postgres (e.g. cct-postgres), NOT localhost.
DATABASE_URL=postgres://cct_app:CHANGE_ME@cct-postgres:5432/customs_control_tower

# --- Session / auth ---
# 32+ random bytes; signs the httpOnly session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_32_PLUS_RANDOM_BYTES
# Session lifetime in hours (default 8).
SESSION_TTL_HOURS=8
# Failed-login attempts before the account is locked (default 5).
LOGIN_MAX_ATTEMPTS=5

# --- Object storage (S3-compatible; MinIO container on the VPS, or external S3) ---
# Internal MinIO service URL, NOT localhost.
S3_ENDPOINT=http://cct-minio:9000
S3_REGION=us-east-1
S3_BUCKET=cct-documents
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
# MinIO requires path-style addressing.
S3_FORCE_PATH_STYLE=true
# Signed retrieval URL lifetime in seconds (default 86400 = 24h).
S3_SIGNED_URL_TTL=86400
# Max document upload size in bytes (default 10 MB).
DOCUMENT_MAX_BYTES=10485760

# --- AI (Anthropic Claude, server-side only) ---
ANTHROPIC_API_KEY=CHANGE_ME
INTERVIEW_MODEL=claude-opus-4-8
FRESHNESS_MODEL=claude-haiku-4-5

# --- Initial admin (consumed by the idempotent seed; not used at runtime) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Freshness scheduler ---
# Cron expression for the scheduled freshness scan (default: daily 06:00). Set FRESHNESS_CRON_ENABLED=false to disable.
FRESHNESS_CRON_ENABLED=true
FRESHNESS_CRON=0 6 * * *
