{
  "name": "@cct/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Customs Control Tower backend — Fastify + TypeScript modular monolith. platform-core, auth-rbac, and the complete Prisma schema for all modules.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "seed": "node --loader ts-node/esm src/seed/seed.ts",
    "start": "node dist/index.js"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm src/seed/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^8.0.3",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "croner": "^8.1.2",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
