{
  "name": "@cct/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Customs Control Tower web SPA (React + Vite + TS + Tailwind). Skeleton only — Builder C builds the views. Uses relative /api paths (no localhost).",
  "scripts": {
    "build": "tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter-tight": "^5.1.0",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@tanstack/react-query": "^5.59.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
